{
  "version": "demo-v1",
  "updated": "2026-05-17",
  "currency": "RMB",
  "scope": "DEMO 数据。配置框架真实可参考；金额是虚构的普通家庭水平。",

  "philosophy": [
    "不是基金组合，是一台『家庭被动现金流机器』：房租 + 股息 + 国债票息 + 黄金对冲",
    "Target 是终局态。DEMO 简化为单房产配置（出租收租金）",
    "**RMB 池 vs USD/HKD 池物理隔离**：人民币出不去，海外子弹只能在海外内部再分配",
    "腾讯减仓顺序：先富途 HKD（成本价高、税少）→ 转 VOO；港股通保留长期主仓",
    "子项阈值仅作『看一眼』提醒（≈ 大类阈值 1/2），唯一强制触发的是红线和大类阈值",
    "**收益率假设保守版**：用于长期安全测算；标普 6% / 黄金 4% / 房产仅算租金 yield 不算升值"
  ],

  "redLines": {
    "singleStockMaxPct":     0.05,
    "rmbMaxPct":             0.70,
    "rmbTargetPct":          0.60,
    "moduleDeviationDefault":0.05
  },

  "inflation": {
    "annual": 0.025,
    "scenarios": {
      "low":      { "annual": 0.015, "label": "低通胀 1.5%（日本化）" },
      "baseline": { "annual": 0.025, "label": "基准 2.5%（CPI 长期均值）" },
      "high":     { "annual": 0.040, "label": "高通胀 4%（货币宽松/输入性）" }
    },
    "default": "baseline",
    "note": "用于刚性支出年化、瀑布图通胀调整、长期增长曲线的实际购买力推算"
  },

  "retirement": {
    "selfRetireYear":  2050,
    "wifeRetireYear":  2050,
    "selfSalaryAnnual": 264000,
    "wifeSalaryAnnual": 144000,
    "stayInChina":  true,
    "kidsAbroad":   false,
    "note": "DEMO：通用占位，朋友请改成自己的退休时间表。改这里时记得同步改 recurring.json 里 salary_* 的 endDate。"
  },

  "milestones": {
    "note": "投资执行行动清单。",
    "items": [
      { "id": "p0_first_cut",        "priority": "P0", "name": "腾讯第一刀（卖等值 30 万 RMB）",          "done": false },
      { "id": "p1_overseas_channel", "priority": "P1", "name": "海外 ETF 通道确认（IBKR/Saxo LSE 通道）",  "done": false, "note": "未开通；blocked UCITS 子项" },
      { "id": "p1_us_estate_plan",   "priority": "P1", "name": "美国资产保护：遗嘱 + NRA 寿险 + situs 清单","done": false },
      { "id": "p2_realloc",          "priority": "P2", "name": "海外 yields 复投到 VOO / IAU",            "done": false },
      { "id": "p3_education_path",   "priority": "P3", "name": "合规教育金建设（kidsAbroad=false 时降级）","done": false },
      { "id": "p3_insurance_review", "priority": "P3", "name": "保险减额缴清评估",                       "done": false },
      { "id": "p3_quarterly_review", "priority": "P3", "name": "季度再平衡纪律：偏离 5% 触发",           "done": false, "ongoing": true }
    ]
  },

  "assumptions": {
    "single_property":   { "value": true,  "label": "单套房产（出租收租金）", "impact": "DEMO 简化模型，不演示『卖房重分配』剧情" },
    "lse_channel_open":  { "value": false, "label": "LSE/UCITS 通道已开通（IBKR/Saxo）", "impact": "未开通时，UCITS 子项标 phase=blocked，VOO 临时承接" },
    "tencent_exit_path": { "value": "futu_first", "label": "腾讯减仓优先级：富途 HKD → 港股通", "impact": "富途 HKD 优先清仓 → 转 VOO；港股通保留" },
    "return_scenario":   { "value": "conservative", "label": "收益率假设档位：保守 / 中性 / 乐观", "impact": "长期推演用保守，复盘看实际" }
  },

  "rebalanceRules": {
    "frequency": "季度末偏离 > 大类阈值触发；子项偏离仅作提醒；红线触发不等周期",
    "preferNewMoney": "优先用工资/股息再投入配平，不卖出已有持仓产生交易成本",
    "method": "大额减仓走 VWAP/不规则节奏，不给市场可预测卖压",
    "poolSeparation": "RMB 池超标只能在 RMB 内部再分配；USD/HKD 池超标只能在海外内部再分配。两池之间不互相补位。"
  },

  "returnAssumptions": {
    "note": "三档年化收益率假设。基于 Shiller 100 年实际数据 + 全球大类资产长期回报研究。默认用保守。",
    "scenarios": {
      "conservative": { "label": "保守（防自欺）",   "color": "#3ddc97" },
      "neutral":      { "label": "中性（合理预期）", "color": "#7aa2ff" },
      "optimistic":   { "label": "乐观（顺风局）",   "color": "#ffb454" }
    }
  },

